# ---- Database (Neon Postgres) ----
# Create a free Neon project -> copy the pooled connection string.
# Without this the site runs in demo mode (orders are not persisted).
DATABASE_URL=

# ---- Moyasar (payments: mada / Visa / Mastercard / STC Pay / Apple Pay) ----
# Get keys from https://dashboard.moyasar.com -> Settings -> API Keys
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=
# Set the same token in Moyasar Dashboard -> Webhooks (endpoint: /api/moyasar/webhook)
MOYASAR_WEBHOOK_SECRET=

# ---- Admin ----
# Open /admin?key=THIS_VALUE to view orders
ADMIN_KEY=change-me

# ---- Optional ----
# WhatsApp number for "order by WhatsApp", international format without +
NEXT_PUBLIC_WHATSAPP=9665XXXXXXXX
NEXT_PUBLIC_SITE_URL=https://qabda.store
